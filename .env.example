# Copy this file to .env and fill in your keys.
# Groq (LLM): free key at https://console.groq.com
GROQ_API_KEY=

# Tavily (web search tool): free key at https://tavily.com
# Optional -- if omitted, the agent's web search tool is skipped
# gracefully (routing/generation still works with docs + specs only).
TAVILY_API_KEY=

# Windows + AVG Antivirus only: AVG's HTTPS traffic inspection re-signs
# outbound TLS connections with its own root cert, which Python doesn't
# trust by default even though the OS/Node.js do -- confirmed live as
# `SSLCertVerificationError: Basic Constraints of CA cert not marked
# critical` against huggingface.co and even pypi.org. Both env vars are
# set because different HTTP client libraries read different ones:
# SSL_CERT_FILE is the standard OpenSSL/httpx one (huggingface_hub
# uses httpx as of the version this project pins), REQUESTS_CA_BUNDLE
# covers anything still using `requests`. Leave both blank if you don't
# have AVG, or hit no SSL errors.
SSL_CERT_FILE=
REQUESTS_CA_BUNDLE=
